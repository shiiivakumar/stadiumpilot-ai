# StadiumPilot AI - Environment Configurations Example
# Copy this file to a new file named '.env' in the root directory.
# NEVER commit your actual '.env' file containing secrets to git repository.

# Google Gemini API Key
# If provided, StadiumPilot AI communicates with Gemini models for conversational logs, briefs, and response plans.
# If left blank or missing, the application runs on a high-fidelity local decision-simulation fallback engine.
VITE_GEMINI_API_KEY=your_gemini_api_key_here
